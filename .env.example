NODE_ENV=development

#== Application
MODULES_SET=monolith
APP_PORT=3000
APP_URL=
APP_TIMEOUT=3000
APP_DEBUG=true

# APP_CORS_ORIGIN values: * | true | false | domain1,domain2,domain3 (comma-separated)
APP_CORS_ORIGIN=http://localhost:3000,http://example.com
LOG_LEVEL=debug
LOG_PRETTY=true
TZ=UTC

#== Database
DB_HOST=localhost
DB_PORT=15432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
DB_USE_SSL=false
ENABLE_ORM_LOGS=error,warn,query 
# Multiple values: [query,schema,error,warn,info,log,migration]

#== Mail
MAIL_FROM=
SEND_GRID_API_KEY=
