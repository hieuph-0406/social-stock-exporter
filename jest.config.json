{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": "src",
  "testRegex": ".*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": [
    "**/*.{!(module|decorator|entity),}.(t|j)s",
    "!**/*.spec.(t|j)s"
  ],
  "coveragePathIgnorePatterns": [
    "/node_modules/",
    "/src/common/class/empty-logger.class.ts",
    "/src/utilities/(app|modules-set|setup-logger|setup-swagger).util.ts"
  ],
  "coverageDirectory": "../coverage",
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^@/api(.*)$": "<rootDir>/api$1",
    "^@/common(.*)$": "<rootDir>/common$1",
    "^@/constants(.*)$": "<rootDir>/constants$1",
    "^@/database(.*)$": "<rootDir>/database$1",
    "^@/decorators(.*)$": "<rootDir>/decorators$1",
    "^@/exceptions(.*)$": "<rootDir>/exceptions$1",
    "^@/health(.*)$": "<rootDir>/health$1",
    "^@/interceptors(.*)$": "<rootDir>/api$1",
    "^@/resources(.*)$": "<rootDir>/resources$1",
    "^@/shared(.*)$": "<rootDir>/shared$1",
    "^@/types(.*)$": "<rootDir>/types$1",
    "^@/utilities(.*)$": "<rootDir>/utilities$1",
    "^@/validation(.*)$": "<rootDir>/validation$1"
  },
  "setupFiles": [
    "../setup-jest.mjs"
  ],
  "cacheDirectory": "../.jest-cache",
  "testTimeout": 120000
}
