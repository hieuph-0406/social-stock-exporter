{
  "name": "admin-server",
  "version": "0.0.1",
  "description": "Admin API service",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:swagger": "yarn build && NODE_ENV=development node dist/generate-swagger.js",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "NODE_ENV=development nest start",
    "start:dev": "yarn build:swagger && yarn build -w & NODE_ENV=development nest start --watch",
    "start:debug": "yarn build -w & NODE_ENV=development nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:detect": "eslint \"{src,apps,libs,test}/**/*.ts\" --max-warnings=4",
    "test": "NODE_ENV=test jest",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:cov": "NODE_ENV=test jest --coverage",
    "test:cov:ci": "NODE_ENV=test jest --ci --json --coverage --testLocationInResults --outputFile=coverage/report.json",
    "test:debug": "NODE_ENV=test node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "NODE_ENV=test jest --config ./test/jest-e2e.json",
    "prepare": "node .husky/install.mjs",
    "typeorm": "typeorm-ts-node-commonjs -d src/database/data-source.ts",
    "migration:up": "yarn typeorm migration:run",
    "migration:down": "yarn typeorm migration:revert",
    "migration:show": "yarn typeorm migration:show",
    "migration:create": "typeorm migration:create ./src/database/migrations/${migration_file_name}",
    "migration:generate": "yarn typeorm migration:generate --pretty ./src/database/migrations/${migration_file_name}"
  },
  "dependencies": {
    "@nestjs/axios": "3.0.2",
    "@nestjs/cli": "10.4.0",
    "@nestjs/common": "10.3.10",
    "@nestjs/config": "3.2.3",
    "@nestjs/core": "10.3.10",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/platform-express": "10.3.10",
    "@nestjs/swagger": "7.4.0",
    "@nestjs/terminus": "10.2.3",
    "@nestjs/typeorm": "10.0.2",
    "@sendgrid/mail": "8.1.3",
    "axios": "1.7.2",
    "bcrypt": "5.1.1",
    "cheerio": "^1.0.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "compression": "1.7.4",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "handlebars": "4.7.8",
    "helmet": "7.1.0",
    "nestjs-pino": "4.1.0",
    "pg": "8.12.0",
    "pino-http": "10.1.0",
    "pino-pretty": "11.2.1",
    "puppeteer": "^24.4.0",
    "typeorm": "0.3.20",
    "uuid": "9.0.1",
    "yaml": "2.4.5"
  },
  "devDependencies": {
    "@commitlint/cli": "19.3.0",
    "@commitlint/config-conventional": "19.2.2",
    "@eslint/js": "9.6.0",
    "@nestjs/schematics": "10.1.2",
    "@nestjs/testing": "10.3.10",
    "@types/bcrypt": "5.0.2",
    "@types/compression": "1.7.5",
    "@types/eslint": "8.56.10",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/node": "20.14.9",
    "@types/supertest": "6.0.2",
    "eslint": "9.6.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.1.3",
    "husky": "9.0.11",
    "jest": "29.7.0",
    "lint-staged": "15.2.7",
    "prettier": "3.3.2",
    "prettier-plugin-organize-imports": "4.0.0",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "ts-jest": "29.1.5",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.5.3",
    "typescript-eslint": "7.15.0",
    "webpack": "5.92.1"
  },
  "resolutions": {
    "@types/mime": "3.0.4",
    "wrap-ansi": "7.0.0",
    "string-width": "4.1.0"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "yarn lint:detect",
      "yarn format",
      "yarn build"
    ]
  },
  "packageManager": "yarn@4.1.1"
}
